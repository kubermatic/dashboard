{
  "compilerOptions": {
    "target": "ES2019",
    "strict": true,
    "sourceMap": false,
    "inlineSourceMap": true,
    "paths": {
      "@kmtypes": ["./types"],
      "@kmtypes/*": ["./types/*"],
      "@intercept/*": ["./intercept/*"],
      "@intercept": ["./intercept"],
      "@pages/*": ["./pages/*"],
      "@utils/*": ["./utils/*"]
    },
    "types": ["cypress"]
  },
  "include": [
    "**/*.ts",
    "../cypress.config.ts"
  ]
}
